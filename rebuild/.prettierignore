# adapter-node writes its production artifact here (see svelte.config.js
# `kit.adapter` -> `out: 'frontend/build'`). Generated, minified bundles;
# never hand-formatted.
frontend/build/

# Generated by MSW (`msw init`) and re-overwritten on every MSW upgrade.
# Letting prettier touch it would create churn on every dependency bump.
frontend/static/mockServiceWorker.js

# Playwright CT writes its Vite bundle into `<templateDir>/.cache/` on
# every CT run (templateDir is `frontend/playwright/` per
# `playwright-ct.config.ts`'s `ctTemplateDir`). Generated minified JS,
# CSS, source maps; never hand-formatted.
frontend/playwright/.cache/

# Hand-curated milestone plans and best-practices docs.
# Prettier treats underscores in identifiers like `UPPER_SNAKE_CASE`,
# `AUTOMATION_*`, `OTEL_*` as Markdown italic markers and corrupts them
# (e.g. `UPPER*SNAKE_CASE`, `OTEL*_`, `OTEL\__`). It also reflows large
# tables into 200+ char lines. The plans are spec / documentation, not
# code, and are reviewed by humans only.
plans/

# Owned by the toolchain, not by us. Keep prettier away so it can never
# silently rewrite scripts/devDependencies/lockfile entries.
package.json
package-lock.json
uv.lock
