# Backend environment overrides for local development.
#
# Copy to `.env` and uncomment the values you want to override. This file is
# read by `app/core/config.py::Settings` (pydantic-settings, `env_file=".env"`,
# resolved relative to the cwd at process start). The Makefile's `migrate`
# target runs `cd backend && alembic ...`, so the loader looks here.
#
# The full set of supported keys, their defaults, and their semantics live in
# `app/core/config.py` and `docs/plans/m0-foundations.md` § Settings(BaseSettings).
# This file mirrors that surface for discoverability; if a key is added there
# but missing here, the source of truth is `config.py`.
#
# Production deployments inject the same keys via the Helm chart's env block
# (`m6-hardening.md` § Helm chart) — the `.env` file is NOT mounted into the
# runtime image. Docker Compose injects them via the `environment:` block on
# the `app` service in `infra/docker-compose.yml`.

# ---- Core ------------------------------------------------------------------
# ENV=dev               # one of dev, test, staging, prod. Drives a few
                        # behavioural switches (CORS, log format under M6).
# HOST=0.0.0.0
# PORT=8080
# LOG_LEVEL=INFO

# ---- Database --------------------------------------------------------------
# Default points at the docker compose service name `mysql`, which only
# resolves inside the compose network. From the host (running `make migrate`
# or invoking pytest), use the published port:
#
#   DATABASE_URL=mysql+asyncmy://rebuild:rebuild@127.0.0.1:13306/rebuild?charset=utf8mb4
#
# Production (Aurora MySQL behind RDS IAM auth) uses the IAM-username form
# with no password and `?ssl=true`; see § IAM database authentication below.
# DATABASE_URL=mysql+asyncmy://rebuild:rebuild@mysql:3306/rebuild?charset=utf8mb4
# DB_POOL_SIZE=10
# DB_POOL_MAX_OVERFLOW=5
# DB_POOL_RECYCLE_SECONDS=1800   # set <900 for belt-and-braces IAM token rotation

# ---- IAM database authentication (Aurora prod / staging only) --------------
# All `DATABASE_IAM_AUTH_*` settings are off by default. When the flag is
# True, the URL above MUST carry an IAM database username with NO password
# (a populated password fails Settings construction). The runtime engine and
# the Alembic migration engine each resolve their IAM user separately so a
# future least-privilege split lands as values-file changes only.
# DATABASE_IAM_AUTH=False
# DATABASE_IAM_AUTH_REGION=          # falls back to AWS_REGION / AWS_DEFAULT_REGION
# DATABASE_IAM_AUTH_HOST=            # override when DATABASE_URL host is a CNAME
# DATABASE_IAM_AUTH_PORT=            # override when DATABASE_URL port is non-3306
# DATABASE_IAM_AUTH_USER=            # runtime engine user (default: URL username)
# DATABASE_IAM_AUTH_MIGRATE_USER=    # migration engine user (default: URL username)

# ---- Redis -----------------------------------------------------------------
# Same hostname caveat as DATABASE_URL — `redis` only resolves inside the
# compose network. From the host:
#
#   REDIS_URL=redis://127.0.0.1:16379/0
# REDIS_URL=redis://redis:6379/0

# ---- Agent gateway (M2 streaming + /api/agents) ----------------------------
# In dev compose this points at the local agent-platform service
# (Pydantic AI + Ollama, see infra/agent-platform/), which surfaces a
# curated set of agents (`dev`, backed by `qwen2.5:0.5b`) so the UI
# works out of the box with no external token. The upstream still
# speaks OpenAI-compatible HTTP at ``/v1/models`` and ``/v1/chat/completions``;
# the rebuild's domain calls each entry an "agent" (each agent has a
# preselected underlying model on the agent platform). Override here
# to point at the real internal agent gateway, LM Studio, vLLM, or any
# other OpenAI-compatible upstream:
#
#   AGENT_GATEWAY_BASE_URL=https://internal-gateway.canva.io/v1
#   AGENT_GATEWAY_API_KEY=...
#
# When unset, the AsyncOpenAI client falls back to https://api.openai.com/v1,
# which 401s without a real OpenAI key.
# AGENT_GATEWAY_BASE_URL=http://agent-platform:8081/v1
# AGENT_GATEWAY_API_KEY=             # SecretStr; injected by the gateway sidecar in prod

# ---- Trusted-header auth (M0) ----------------------------------------------
# Headers stamped by the OAuth2 proxy upstream of the FastAPI app. The
# allowlist is empty by default (any header value accepted). Set to a CSV
# of domains to reject off-domain headers with HTTP 401:
#
#   TRUSTED_EMAIL_DOMAIN_ALLOWLIST=canva.com,canva.io
# TRUSTED_EMAIL_HEADER=X-Forwarded-Email
# TRUSTED_NAME_HEADER=X-Forwarded-Name
# TRUSTED_EMAIL_DOMAIN_ALLOWLIST=

# ---- File uploads (M4) -----------------------------------------------------
# MAX_UPLOAD_BYTES=5242880          # 5 MiB; matches rebuild.md §9

# ---- CORS ------------------------------------------------------------------
# CSV. Empty = no Access-Control-Allow-Origin header (same-origin only).
# In dev compose the app service sets this to http://localhost:5173 so the
# Vite dev server can hit the API directly during development.
# CORS_ALLOW_ORIGINS=http://localhost:5173

# ---- Readyz timeouts -------------------------------------------------------
# READYZ_DB_TIMEOUT_MS=1000
# READYZ_REDIS_TIMEOUT_MS=500

# ---- Streaming (M2) --------------------------------------------------------
# Whole-request cap on POST /api/chats/{id}/messages. Wrapped around the
# provider iteration via `async with asyncio.timeout(...)` inside the M2
# streaming generator so the persist-partial branch owns the cleanup path.
# MUST equal the M6 per-route HTTP timeout for /api/chats/{id}/messages.
# SSE_STREAM_TIMEOUT_SECONDS=300
