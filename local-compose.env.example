# Copy this file to `.env` when running Open WebUI locally against services
# that are still started by docker-compose.
#
# Important:
# - The local Open WebUI backend runs on http://localhost:5080
# - The local frontend dev server runs on http://localhost:5173
# - Your compose-published `agents` host port must NOT also be 5080
#
# If MySQL on `localhost` gives IPv6 connection issues on macOS, switch the
# host below to `127.0.0.1`.
#
# All values are double-quoted so this file parses cleanly under both
# `uv run --env-file` (strict dotenv parser) and docker-compose env_file
# (compose strips the outer quotes).

OPENAI_API_BASE_URL="http://localhost:8081/v1"
OPENAI_API_BASE_URLS="http://localhost:8081/v1"
OPENAI_API_KEYS="dummy"
# Prevent default local embedding models from being pulled from Hugging Face.
OFFLINE_MODE="true"
RAG_EMBEDDING_ENGINE="openai"
RAG_OPENAI_API_BASE_URL="http://localhost:8081/v1"
RAG_OPENAI_API_KEY="dummy"
ENABLE_OLLAMA_API="false"
ENABLE_EVALUATION_ARENA_MODELS="false"
ENABLE_API_KEYS="true"
WEBUI_AUTH="false"
WEBUI_NAME="Canva Agents Platform"
DEFAULT_USER_ROLE="admin"
ENABLE_NOTES="false"

DATABASE_TYPE="mysql"
DATABASE_HOST="localhost"
DATABASE_PORT="3306"
DATABASE_NAME="openwebui"
DATABASE_USER="openwebui"
DATABASE_PASSWORD="openwebui"

# Service-account admin user reconciled on every boot. Used by the
# agent-platform sync job to push models and skills into the DB.
# The API key is what the syncer sends as `Authorization: Bearer <key>`;
# it MUST start with `sk-` so the auth dispatcher routes it to the
# API-key path instead of trying to parse it as a JWT.
OPENWEBUI_SYNC_USERNAME="agent-platform-sync@local"
OPENWEBUI_SYNC_PASSWORD="agent-platform-auto-provisioned-key"
OPENWEBUI_SYNC_NAME="Agent Platform"
OPENWEBUI_SYNC_API_KEY="sk-agent-platform-auto-provisioned-key"

CORS_ALLOW_ORIGIN="http://localhost:5173;http://localhost:5080"
FORWARDED_ALLOW_IPS="*"
